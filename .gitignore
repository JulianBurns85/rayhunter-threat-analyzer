# ============================================================
# rayhunter-threat-analyzer .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.env
.venv
venv/
env/
dist/
build/
*.egg-info/
.eggs/

# --- Case output files — NEVER commit these ---
# Exhibit files
exhibit_*.txt
exhibit_*.json

# Warrant and submission documents
warrant_*.txt
AFP_*.txt
afp_master_submission.py
*_submission_*.txt
*_submission_*.json

# Analysis outputs (run locally, share via Drive)
*.html
report_*.json
manifest_*.json
manifest_*.csv
forensic_report_*.json
*_dossier.txt
*_dossier.json
rsrp_castnet_report.txt

# Archive folder
archive/

# --- Capture data — never commit raw RF captures ---
*.ndjson
*.pcap
*.pcapng
*.qmdl
*.iq
*.sigmf-data
*.sigmf-meta
captures/
data/
raw/

# --- Keys, credentials ---
*.key
*.pem
*.env
secrets.yaml
config_local.yaml

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
